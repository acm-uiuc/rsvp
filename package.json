{
  "name": "rsvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env VITE_RUN_ENVIRONMENT=local-dev vite",
    "dev:qa": "cross-env VITE_RUN_ENVIRONMENT=dev vite",
    "build": "tsc && vite build",
    "build:dev": "cross-env VITE_RUN_ENVIRONMENT=dev tsc && vite build",
    "build:prod": "cross-env VITE_RUN_ENVIRONMENT=prod tsc && vite build",
    "preview": "cross-env VITE_RUN_ENVIRONMENT=local-dev vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "test": "npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@acm-uiuc/core-client": "^4.9.4",
    "@acm-uiuc/js-shared": "^3.8.3",
    "@azure/msal-browser": "^5.9.0",
    "@azure/msal-react": "^5.3.2",
    "@mantine/core": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@marsidev/react-turnstile": "^1.5.1",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/vite": "^4.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-qr-code": "^2.0.21",
    "react-router-dom": "^7.14.2",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
